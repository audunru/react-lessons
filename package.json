{
	"name": "react-lessons",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build --base /react-lessons",
		"biome:check": "biome check",
		"biome:write": "biome check --write",
		"preview": "vite preview",
		"prepare": "husky"
	},
	"dependencies": {
		"@reduxjs/toolkit": "^2.11.2",
		"@tanstack/react-query": "^5.100.9",
		"clsx": "^2.1.1",
		"highlight.js": "^11.11.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-helmet": "^6.1.0",
		"react-hook-form": "^7.75.0",
		"react-redux": "^9.2.0",
		"react-router-dom": "^7.15.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/react": "^18.3.28",
		"@types/react-dom": "^18.3.7",
		"@types/react-helmet": "^6.1.11",
		"@vitejs/plugin-react": "^4.7.0",
		"autoprefixer": "^10.5.0",
		"globals": "^15.15.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.3",
		"postcss": "^8.5.14",
		"tailwindcss": "^3.4.19",
		"typescript": "~5.9.3",
		"vite": "^6.4.2"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,md,json}": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}
